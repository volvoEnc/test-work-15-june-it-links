{
  "name": "test-work/car-api-yii2",
  "description": "Dockerized Yii2 REST API for car listings.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "yiisoft/yii2": "^2.0.52"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "app\\": ""
    }
  },
  "autoload-dev": {
    "psr-4": {
      "tests\\": "tests/"
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ],
  "config": {
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    },
    "process-timeout": 1800,
    "sort-packages": true
  },
  "scripts": {
    "test": "phpunit"
  }
}
